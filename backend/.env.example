# Environment
NODE_ENV=development
PORT=5001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=info

# Deeplink Security
# IMPORTANT: Change this in production! Minimum 32 characters
DEEPLINK_SECRET=change-this-secret-in-production-min-32-chars-required

# Optional: Uncomment when you add database support
# DATABASE_URL="postgresql://user:password@localhost:5432/rkhospital?schema=public"

# Optional: Uncomment when you add authentication
# JWT_SECRET=your-secret-key-change-in-production
